# Configurações do Sistema Starke ST
# Copie este arquivo para .env e configure suas credenciais

# ===========================================
# CONFIGURAÇÕES DE EMAIL
# ===========================================
# Email usado para enviar notificações
EMAIL_USER=starkestsuportetecnico@gmail.com

# Senha de app do Gmail (NÃO use sua senha normal)
# Como obter: https://support.google.com/accounts/answer/185833
EMAIL_PASSWORD=

# ===========================================
# CONFIGURAÇÕES DE ADMINISTRAÇÃO
# ===========================================
# Senha para acesso administrativo
# Email padrão: Superadm@starkeST.com
STARKE_ADMIN_PASSWORD=Starke@2025

# ===========================================
# CONFIGURAÇÕES DO FLASK
# ===========================================
# Ambiente de execução (development/production)
FLASK_ENV=development

# Modo debug (True/False)
FLASK_DEBUG=True

# Chave secreta para sessões (gere uma nova para produção)
SECRET_KEY=your-secret-key-here

# ===========================================
# CONFIGURAÇÕES DE BANCO DE DADOS
# ===========================================
# Caminho para o arquivo do banco SQLite
DATABASE_PATH=backend/database.sqlite3

# ===========================================
# CONFIGURAÇÕES DE CORS
# ===========================================
# URLs permitidas para requisições CORS
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5000

# ===========================================
# CONFIGURAÇÕES DE LOG
# ===========================================
# Nível de log (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# Arquivo de log
LOG_FILE=app.log

# ===========================================
# CONFIGURAÇÕES DE PRODUÇÃO (OPCIONAL)
# ===========================================
# Host para produção
PRODUCTION_HOST=0.0.0.0

# Porta para produção
PRODUCTION_PORT=5000

# Número de workers para Gunicorn
WORKERS=4

# ===========================================
# CONFIGURAÇÕES DE BACKUP (OPCIONAL)
# ===========================================
# Pasta para backups automáticos
BACKUP_PATH=backups

# Frequência de backup (dias)
BACKUP_FREQUENCY=7

# ===========================================
# CONFIGURAÇÕES DE MONITORAMENTO (OPCIONAL)
# ===========================================
# Ativar métricas de performance
ENABLE_METRICS=True

# Intervalo de coleta de métricas (segundos)
METRICS_INTERVAL=60

# ===========================================
# INSTRUÇÕES DE CONFIGURAÇÃO
# ===========================================
# 1. Copie este arquivo para .env
# 2. Configure EMAIL_PASSWORD com senha de app do Gmail
# 3. Altere STARKE_ADMIN_PASSWORD para uma senha segura
# 4. Para produção, configure FLASK_ENV=production
# 5. Gere uma SECRET_KEY única para produção
# 6. Reinicie o servidor após as alterações

# ===========================================
# EXEMPLO DE CONFIGURAÇÃO COMPLETA
# ===========================================
# EMAIL_USER=seu-email@gmail.com
# EMAIL_PASSWORD=sua-senha-de-app-aqui
# STARKE_ADMIN_PASSWORD=MinhaSenh@Segura123
# FLASK_ENV=production
# FLASK_DEBUG=False
# SECRET_KEY=uma-chave-secreta-muito-longa-e-aleatoria
# DATABASE_PATH=backend/database.sqlite3
# CORS_ORIGINS=https://seudominio.com,https://www.seudominio.com
# LOG_LEVEL=INFO
# LOG_FILE=app.log
